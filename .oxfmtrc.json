{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "useTabs": false,
  "tabWidth": 2,
  "singleQuote": false,
  "trailingComma": "all",
  "semi": true,
  "bracketSpacing": true,
  "arrowParens": "always",
  "ignorePatterns": ["dist/**", "src-tauri/target/**", "src-tauri/vendor/**", "flatpak/node-sources.json"]
}
