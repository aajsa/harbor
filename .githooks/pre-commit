#!/bin/sh
set -eu

files=$(git diff --cached --name-only --diff-filter=ACMR | rg '\.(js|jsx|mjs|cjs|ts|tsx|mts|cts|json|jsonc)$' || true)

if [ -z "$files" ]; then
  exit 0
fi

printf '%s\n' 'Formatting staged files...'
printf '%s\n' "$files" | while IFS= read -r file; do
  pnpm exec oxfmt --write "$file"
  git add -- "$file"
done
